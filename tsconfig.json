{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "sourceMap": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["src"]
}